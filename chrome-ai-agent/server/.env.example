PORT=3000

# Default provider: openai_api_key, claude_api_key, openai_signin_codex, or local_model
RUNTIME_PROVIDER=openai_api_key

# OpenAI API key mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Claude API key mode
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI sign-in through local Codex CLI mode
CODEX_CLI_COMMAND=codex
CODEX_MODEL=gpt-5.5

# Local OpenAI-compatible model mode, for example Ollama on /v1
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_API_KEY=ollama
LOCAL_MODEL=llama3.1
