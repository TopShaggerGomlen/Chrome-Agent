PORT=3000

# Default provider: openai_api_key, claude_api_key, openai_signin_codex,
# deepseek_r1_ollama, or gpt_oss_20b_ollama
RUNTIME_PROVIDER=openai_api_key

# OpenAI API key mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Claude API key mode
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI sign-in through local Codex CLI mode
CODEX_CLI_COMMAND=codex
CODEX_MODEL=gpt-5.5

# Ollama self-hosted model modes
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
DEEPSEEK_R1_MODEL=deepseek-r1
GPT_OSS_20B_MODEL=gpt-oss:20b

# Excel workbook support (optional; leave WORKBOOK_PATH_ALIASES empty to keep
# workbook routes disabled). Values are JSON; backslashes in Windows paths are
# escaped. Configure once, then use the aliases rather than accepting arbitrary
# paths from the browser.
WORKBOOK_PATH_ALIASES={"canonical":"C:\\Path\\To\\Approved\\working-copy.xlsx","desktop":"C:\\Path\\To\\Desktop\\working-copy.xlsx"}
WORKBOOK_ALLOWED_ROOTS=["C:\\Path\\To\\Approved","C:\\Path\\To\\Desktop"]
# Optional pinned filename (for example, working-copy.xlsx); blank permits any
# supported .xlsx name under an allowed root.
WORKBOOK_BASENAME=
WORKBOOK_BACKUP_DIR=.workbook-backups
WORKBOOK_AUDIT_DIR=.workbook-audit
WORKBOOK_JOURNAL_DIR=.workbook-journal
WORKBOOK_BACKUP_RETENTION_DAYS=10
WORKBOOK_BACKUP_MAX=100
